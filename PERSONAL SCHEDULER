    # ──────────────────────────────────────────────────────────────────────────
    # BACKGROUND TOPLEVEL (sits behind the transparent main window)
    # ──────────────────────────────────────────────────────────────────────────

    def _enable_bg_window(self):
        try:
            self.root.wm_attributes("-transparentcolor", TKEY)
        except Exception:
            pass
        self._ensure_bg_win()
        self.root.bind("<Configure>", self._schedule_bg_sync)
        self._schedule_bg_sync()

    def _ensure_bg_win(self):
        if self._bg_win and self._bg_win.winfo_exists():
            return
        self._bg_win = tk.Toplevel(self.root)
        self._bg_win.overrideredirect(True)
        try:
            self._bg_win.wm_attributes("-toolwindow", True)
        except Exception:
            pass
        self._bg_win.lower(self.root)
        self._bg_lbl = tk.Label(self._bg_win, bd=0, highlightthickness=0)
        self._bg_lbl.pack(fill="both", expand=True)

    def _schedule_bg_sync(self, _=None):
        if self._bg_sync_job:
            try: self.root.after_cancel(self._bg_sync_job)
            except Exception: pass
        self._bg_sync_job = self.root.after(60, self._sync_bg_win)

    def _sync_bg_win(self):
        self._bg_sync_job = None
        if not (self._bg_win and self._bg_win.winfo_exists()):
            return
        try:
            x, y = self.root.winfo_rootx(), self.root.winfo_rooty()
            w, h = self.root.winfo_width(), self.root.winfo_height()
            if w > 1 and h > 1:
                self._bg_win.geometry(f"{w}x{h}+{x}+{y}")
                self._bg_win.lower(self.root)
        except Exception:
            pass

    # ──────────────────────────────────────────────────────────────────────────
    # BACKGROUND IMAGE LOAD & ANIMATE
    # ──────────────────────────────────────────────────────────────────────────

    def _load_bg_image(self):
        settings = self._load_settings()
        self._bg_overlay_strength = float(settings.get("background_overlay_strength", 0.38))
        bg_name = (settings.get("background_file") or "").strip()

        candidates = ([self.folder / bg_name] if bg_name else []) + \
                     [self.folder / f"background{e}" for e in (".gif", ".png", ".jpg", ".jpeg")]

        self.bg_frames = []
        for p in candidates:
            if not p.exists():
                continue
            try:
                img = Image.open(p)
                try:
                    for i in range(img.n_frames):
                        img.seek(i)
                        self.bg_frames.append(img.copy())
                except Exception:
                    self.bg_frames = [img.copy()]
                self.bg_frame_idx = 0
                return
            except Exception:
                pass

    def _start_bg(self):
        if not self.bg_frames:
            return
        self._ensure_bg_win()
        if not self._bg_cfg_bound:
            self._bg_cfg_bound = True
            self.root.bind("<Configure>", self._on_root_resize)
        self._draw_bg()

    def _on_root_resize(self, _=None):
        self._schedule_bg_sync()
        if self._bg_resize_job:
            try: self.root.after_cancel(self._bg_resize_job)
            except Exception: pass
        self._bg_resize_job = self.root.after(100, self._draw_bg)

    def _draw_bg(self):
        if self._bg_anim_job:
            try: self.root.after_cancel(self._bg_anim_job)
            except Exception: pass
            self._bg_anim_job = None

        if not self.bg_frames or not (self._bg_lbl and self._bg_lbl.winfo_exists()):
            return
        try:
            w = self.root.winfo_width()
            h = self.root.winfo_height()
            if w < 2 or h < 2:
                return

            frame = self.bg_frames[self.bg_frame_idx]
            fw, fh = frame.size
            scale  = max(w / fw, h / fh)
            nw, nh = max(1, int(fw * scale)), max(1, int(fh * scale))
            scaled  = frame.resize((nw, nh), Image.Resampling.LANCZOS)
            l, t   = max(0, (nw - w) // 2), max(0, (nh - h) // 2)
            cropped = scaled.crop((l, t, l + w, t + h))

            # Dark-navy tint overlay keeps the glass panels readable
            overlay = Image.new("RGB", (w, h), "#08101e")
            blended = Image.blend(cropped.convert("RGB"), overlay,
                                  self._bg_overlay_strength)

            self.bg_photo = ImageTk.PhotoImage(blended)
            self._bg_lbl.config(image=self.bg_photo)
            self._sync_bg_win()

            if len(self.bg_frames) > 1:
                self.bg_frame_idx = (self.bg_frame_idx + 1) % len(self.bg_frames)
                self._bg_anim_job = self.root.after(110, self._draw_bg)
        except Exception as e:
            print(f"[BG] {e}")

    def choose_background(self):
        path = filedialog.askopenfilename(
            title="Choose Background",
            filetypes=[("Images", "*.gif *.png *.jpg *.jpeg")])
        if not path:
            return
        src = Path(path)
        if src.suffix.lower() not in {".gif", ".png", ".jpg", ".jpeg"}:
            messagebox.showerror("Background", "Select a GIF, PNG, or JPG.")
            return
        dest = self.folder / f"background_custom{src.suffix.lower()}"
        try:
            dest.write_bytes(src.read_bytes())
        except Exception:
            messagebox.showerror("Background", "Could not copy file.")
            return
        s = self._load_settings()
        s["background_file"] = dest.name
        self._save_settings(s)
        self._load_bg_image()
        self._start_bg()

