    def show_login(self):
        self.clear_window()
        self._start_bg()

        box = tk.Frame(self.root, bg=PANEL_BG,
                       highlightthickness=1, highlightbackground=GLASS_BORDER)
        box.place(relx=0.5, rely=0.5, anchor="center", width=420, height=350)

        tk.Label(box, text="VIAM", font=("Segoe UI", 30, "bold"),
                 bg=PANEL_BG, fg=CLR_HEADER).pack(pady=(26, 0))
        tk.Label(box, text="Personal Scheduler", font=("Segoe UI", 10),
                 bg=PANEL_BG, fg=CLR_TEXT_MUTED).pack(pady=(0, 6))
        ttk.Separator(box).pack(fill="x", padx=24, pady=6)

        def field(lbl, **kw):
            tk.Label(box, text=lbl, bg=PANEL_BG,
                     font=("Segoe UI", 9, "bold"), fg=CLR_TEXT_LABEL).pack(anchor="w", padx=28)
            e = self._entry(box, width=32, **kw)
            e.pack(pady=(2, 10), padx=28, ipady=5)
            return e

        u_e = field("Username")
        p_e = field("Password", show="*")

        bf = tk.Frame(box, bg=PANEL_BG)
        bf.pack(pady=6)
        self._btn(bf, "Login",    lambda: self.login(u_e.get(), p_e.get()),
                  CLR_HEADER, padx=14, pady=5).pack(side="left", padx=5)
        self._btn(bf, "Register", self.show_register,
                  CLR_SUCCESS, padx=14, pady=5).pack(side="left", padx=5)
        box.lift()

    def show_register(self):
        self.clear_window()
        self._start_bg()

        box = tk.Frame(self.root, bg=PANEL_BG,
                       highlightthickness=1, highlightbackground=GLASS_BORDER)
        box.place(relx=0.5, rely=0.5, anchor="center", width=430, height=450)

        tk.Label(box, text="Create Account", font=("Segoe UI", 17, "bold"),
                 bg=PANEL_BG, fg=CLR_HEADER).pack(pady=(22, 4))
        ttk.Separator(box).pack(fill="x", padx=24, pady=6)

        entries = {}
        for lbl, kw in [("Username", {}), ("Email", {}),
                        ("Password", {"show": "*"}),
                        ("Confirm Password", {"show": "*"})]:
            tk.Label(box, text=lbl, bg=PANEL_BG,
                     font=("Segoe UI", 9, "bold"), fg=CLR_TEXT_LABEL).pack(anchor="w", padx=26)
            e = self._entry(box, width=32, **kw)
            e.pack(pady=(2, 9), padx=26, ipady=4)
            entries[lbl] = e

        self._btn(box, "Create Account",
                  lambda: self.register(
                      entries["Username"].get(), entries["Email"].get(),
                      entries["Password"].get(), entries["Confirm Password"].get()),
                  CLR_SUCCESS, padx=18, pady=6).pack(pady=8)
        tk.Button(box, text="← Back to Login", command=self.show_login,
                  bg=PANEL_BG, fg=CLR_EVT, relief=tk.FLAT,
                  cursor="hand2", font=("Segoe UI", 9)).pack()
        box.lift()

    def login(self, username, password):
        username = (username or "").strip()
        if not username or not password:
            messagebox.showerror("Login", "Please enter username and password.")
            return
        rec = self.load_users().get(username.lower())
        if not rec or self.hash_password(password) != rec["password_hash"]:
            messagebox.showerror("Login", "Wrong username or password.")
            return
        self.current_user = {"username": rec["username"]}
        self.show_main()

    def register(self, username, email, password, confirm):
        username, email = (username or "").strip(), (email or "").strip()
        if not username or not email or not password:
            messagebox.showerror("Register", "Please fill in all fields.")
            return
        if password != confirm:
            messagebox.showerror("Register", "Passwords do not match.")
            return
        if not re.match(r"^[^@]+@[^@]+\.[^@]+", email):
            messagebox.showerror("Register", "Email is not valid.")
            return
        if username.lower() in self.load_users():
            messagebox.showerror("Register", "Username already taken.")
            return
        self.save_user(username, email, self.hash_password(password))
        messagebox.showinfo("Register", "Account created! You can log in now.")
        self.show_login()

