        # TKEY bg on ttk containers keeps them transparent (main window shows through)
        s.configure(".",               background=TKEY, foreground=CLR_TEXT)
        s.configure("TFrame",          background=TKEY)
        s.configure("TLabel",          background=TKEY, foreground=CLR_TEXT)
        s.configure("TSeparator",      background=GLASS_BORDER)
        s.configure("TNotebook",       background=TKEY, borderwidth=0, tabmargins=0)
        s.configure("TNotebook.Tab",   padding=[18, 9], font=("Segoe UI", 10, "bold"),
                    background="#0b1830", foreground=CLR_TEXT_MUTED, borderwidth=0)
        s.map("TNotebook.Tab",
              background=[("selected", CLR_HEADER), ("active", "#142040")],
              foreground=[("selected", "white"),     ("active", CLR_TEXT)])
        s.configure("Treeview",        rowheight=28, font=("Segoe UI", 10),
                    background=CLR_INPUT_BG, foreground=CLR_TEXT,
                    fieldbackground=CLR_INPUT_BG, borderwidth=0)
        s.configure("Treeview.Heading",font=("Segoe UI", 10, "bold"),
                    background="#0b1830", foreground=CLR_TEXT_LABEL)
        s.map("Treeview",              background=[("selected", CLR_SELECTED)])
        s.configure("TCombobox",       background=CLR_INPUT_BG, foreground=CLR_TEXT,
