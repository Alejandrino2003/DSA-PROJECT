        self._clock_job     = None
        self._quote_job     = None
        self._quote_index   = 0
        self.notebook       = None

        # Background engine
        self.bg_frames           = []
        self.bg_frame_idx        = 0
        self.bg_photo            = None
        self._bg_win             = None
        self._bg_lbl             = None
        self._bg_anim_job        = None
        self._bg_sync_job        = None
