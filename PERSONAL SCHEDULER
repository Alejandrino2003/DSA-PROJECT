        self.calendar = tkc.Calendar(
            cal_card, selectmode="day", date_pattern="yyyy-mm-dd",
            font=("Segoe UI", 10),
            background=PANEL_BG,        foreground=CLR_TEXT,
            bordercolor=GLASS_BORDER,
            headersbackground="#07101e", headersforeground="#90b8f0",
            selectbackground=CLR_HEADER, selectforeground="white",
            normalbackground=PANEL_BG,  normalforeground=CLR_TEXT,
            weekendbackground="#0b1830", weekendforeground="#7a9cc8",
            othermonthbackground="#081018", othermonthforeground="#2a3f60",
            cursor="hand2")
        self.calendar.pack(padx=10, pady=10)
        self.calendar.bind("<<CalendarSelected>>", self._on_cal_select)
        self.calendar.bind("<Double-1>",            self._on_cal_dblclick)

        # Legend
        legend = tk.Frame(cal_card, bg=PANEL_BG)
        legend.pack(pady=(0, 12))
        for dot, lbl in [("#4db8ff", " event"), ("#ffd166", " to-do"),
                         ("#2e9e4f", " both"),  ("#c084fc", " today")]:
            tk.Label(legend, text="●", fg=dot, bg=PANEL_BG,
                     font=("Segoe UI", 11, "bold")).pack(side="left", padx=(6, 0))
            tk.Label(legend, text=lbl, fg=CLR_TEXT_MUTED,
                     bg=PANEL_BG, font=("Segoe UI", 8)).pack(side="left")

        # Day events panel
        right = tk.Frame(outer, bg=PANEL_BG,
                         highlightthickness=1, highlightbackground=GLASS_BORDER)
        right.pack(side="left", fill="both", expand=True, padx=10, pady=10)

        self._day_lbl = tk.Label(right, text="", font=("Segoe UI", 13, "bold"),
                                 bg=PANEL_BG, fg=CLR_TEXT)
        self._day_lbl.pack(anchor="w", padx=16, pady=(16, 2))
        tk.Label(right, text="Events for selected date",
                 font=("Segoe UI", 9), bg=PANEL_BG,
                 fg=CLR_TEXT_MUTED).pack(anchor="w", padx=16)

        ev_wrap = tk.Frame(right, bg=CLR_INPUT_BG,
                           highlightthickness=1, highlightbackground=GLASS_BORDER)
        ev_wrap.pack(fill="both", expand=True, padx=16, pady=(8, 16))

        self._ev_list = tk.Listbox(ev_wrap, font=("Segoe UI", 10),
                                   bg=CLR_INPUT_BG, fg=CLR_TEXT,
                                   selectbackground=CLR_SELECTED,
                                   highlightthickness=0, bd=0,
                                   relief=tk.FLAT, activestyle="none")
        self._ev_list.pack(fill="both", expand=True, padx=6, pady=6)

        self._on_cal_select()
        self._refresh_cal_tags()

    def _on_cal_select(self, _=None):
        self._selected_date = self.calendar.get_date()
        try:
            d = datetime.strptime(self._selected_date, "%Y-%m-%d")
            prefix = "Today — " if self._selected_date == datetime.now().strftime("%Y-%m-%d") else ""
            self._day_lbl.config(text=f"{prefix}{d.strftime('%A, %B %d %Y')}")
        except Exception:
            self._day_lbl.config(text=self._selected_date)
        self._load_day_events(self._selected_date)

    def _on_cal_dblclick(self, _=None):
        """Double-click: jump to Add Items tab, pre-fill date."""
        self.notebook.select(self.tab_add)
        try:
            self._ai_date_var.set(self.calendar.get_date())
        except Exception:
            pass

    def _refresh_cal_tags(self):
        try:
            data = self.load_data()
            self.calendar.calevent_remove("all")
            self.calendar.tag_config("ev",    background="#102050")
            self.calendar.tag_config("td",    background="#2a1e00")
            self.calendar.tag_config("both",  background="#0a2a18")
            self.calendar.tag_config("today", background="#220d40")

            ev_dates = {e["start_time"][:10] for e in data["events"]
                        if len(e.get("start_time", "")) >= 10}
            td_dates = {d for d, v in data["daily_todos"].items() if v}
            today    = datetime.now().strftime("%Y-%m-%d")

            for d in ev_dates | td_dates | {today}:
                try:
                    obj = datetime.strptime(d, "%Y-%m-%d").date()
                except Exception:
                    continue
                tag = ("both"  if d in ev_dates and d in td_dates
                       else "ev"    if d in ev_dates
                       else "td"    if d in td_dates
                       else "today")
                self.calendar.calevent_create(obj, "", tag)
        except Exception:
            pass

    def _load_day_events(self, date_str):
        self._ev_list.delete(0, tk.END)
        events = sorted([e for e in self.load_data()["events"]
                         if e.get("start_time", "")[:10] == date_str],
                        key=lambda x: x.get("start_time", ""))
        if not events:
            self._ev_list.insert(tk.END, "  (No events this day)")
            return
        for ev in events:
            try:
                st = datetime.fromisoformat(ev["start_time"])
                en = datetime.fromisoformat(ev["end_time"])
                line = (f"  {st.strftime('%I:%M %p').lstrip('0')} – "
                        f"{en.strftime('%I:%M %p').lstrip('0')}  ·  {ev.get('title','')}")
            except Exception:
                line = f"  {ev.get('title','?')}"
            if ev.get("location"):
                line += f"  @ {ev['location']}"
            line += {"High": "  🔴", "Medium": "  🟡",
                     "Low": "  🟢"}.get(ev.get("priority", ""), "")
            self._ev_list.insert(tk.END, line)

