    # DASHBOARD
    # ══════════════════════════════════════════════════════════════════════════

    def _build_dashboard(self):
        outer = tk.Frame(self.tab_dash, bg=TKEY)
        outer.pack(fill="both", expand=True, padx=10, pady=10)

        # Stat cards
        row = tk.Frame(outer, bg=TKEY)
        row.pack(fill="x", pady=(0, 10))

        self._stat_lbls  = {}
        self._stat_cards = {}
        for key, label, color in [
            ("total_events",  "Total Events",      CLR_EVT),
            ("upcoming",      "Upcoming (7 days)", CLR_HEADER),
            ("overdue_tasks", "Overdue Tasks",      CLR_DANGER),
            ("pending_todos", "Pending To-Dos",     CLR_TODO),
            ("streak",        "Day Streak 🔥",      CLR_SUCCESS),
        ]:
            card = tk.Frame(row, bg=PANEL_BG, highlightthickness=1,
                            highlightbackground=color, cursor="hand2")
            card.pack(side="left", fill="both", expand=True, padx=5)
            card.bind("<Button-1>", lambda e, k=key: self._card_click(k))
            tk.Label(card, text=label, font=("Segoe UI", 8, "bold"),
                     bg=PANEL_BG, fg=CLR_TEXT_MUTED).pack(pady=(12, 2))
            v = tk.Label(card, text="—", font=("Segoe UI", 24, "bold"),
                         bg=PANEL_BG, fg=color)
            v.pack(pady=(0, 12))
            v.bind("<Button-1>", lambda e, k=key: self._card_click(k))
            self._stat_lbls[key]  = v
            self._stat_cards[key] = card

        # Overdue / Upcoming panels
        mid = tk.Frame(outer, bg=TKEY)
        mid.pack(fill="both", expand=True)

        def info_panel(title, color):
            f = tk.Frame(mid, bg=PANEL_BG, highlightthickness=1,
                         highlightbackground=GLASS_BORDER)
            f.pack(side="left", fill="both", expand=True, padx=5)
            tk.Label(f, text=title, font=("Segoe UI", 11, "bold"),
                     bg=PANEL_BG, fg=color).pack(anchor="w", padx=14, pady=(12, 4))
            box = tk.Text(f, height=10, font=("Segoe UI", 9),
                          bg=CLR_INPUT_BG, fg=CLR_TEXT, relief=tk.FLAT,
                          state="disabled", wrap="word", padx=8, pady=4)
            box.pack(fill="both", expand=True, padx=10, pady=(0, 12))
            return box

        self._overdue_box  = info_panel("⚠️  Overdue / Due Today", CLR_DANGER)
        self._upcoming_box = info_panel("📅  Next 7 Days",          CLR_HEADER)

        # Quote + refresh
        bot = tk.Frame(outer, bg=TKEY)
        bot.pack(fill="x", pady=(10, 0))
        self._quote_lbl = tk.Label(bot, text="", font=("Segoe UI", 9, "italic"),
                                   bg=TKEY, fg=CLR_TEXT_MUTED, wraplength=820)
        self._quote_lbl.pack(side="left", padx=4)
        self._btn(bot, "↻  Refresh", self._refresh_dashboard,
                  CLR_HEADER, padx=10, pady=3).pack(side="right", padx=4)

        self._refresh_dashboard()
        self._rotate_quote()

    def _card_click(self, key):
        for k, card in self._stat_cards.items():
            clr = CLR_SELECTED if k == key else PANEL_BG
            card.configure(bg=clr)
            for ch in card.winfo_children():
                if isinstance(ch, tk.Label):
                    ch.configure(bg=clr)

    def _refresh_dashboard(self):
        data  = self.load_data()
        today = datetime.now().date()
        in7   = today + timedelta(days=7)

        evs       = data["events"]
        total_ev  = len(evs)
        upcoming7 = sum(1 for e in evs if (s := e.get("start_time", ""))
                        and today <= datetime.fromisoformat(s).date() <= in7)
        overdue   = [t for t in data["tasks"] if t.get("status") != "Completed"
                     and self._date_part(t.get("due_date", "")) < today.isoformat()]
        due_today = [t for t in data["tasks"] if t.get("status") != "Completed"
                     and self._date_part(t.get("due_date", "")) == today.isoformat()]
        pending   = sum(sum(1 for x in v if not x.get("done"))
                        for v in data["daily_todos"].values())
        streak    = self._calc_streak(data)

        for key, val in [("total_events", total_ev), ("upcoming", upcoming7),
                         ("overdue_tasks", len(overdue)),
                         ("pending_todos", pending), ("streak", streak)]:
            self._stat_lbls[key].config(text=str(val))

        def fill(box, lines, empty_msg):
            box.config(state="normal")
            box.delete("1.0", "end")
            box.insert("end", "\n".join(lines) + "\n" if lines else f"  {empty_msg}\n")
            box.config(state="disabled")

        urgent = [
            f"  {'⚠️' if f == 'o' else '⏰'} [TASK]  {t.get('title','')}  ({t.get('due_date','')[:10]})"
            for t, f in [(t, "o") for t in overdue] + [(t, "t") for t in due_today]
        ]
        fill(self._overdue_box, urgent, "No overdue items. Great job! ✅")

        ev_sorted = sorted(
            [e for e in evs if (s := e.get("start_time", ""))
             and today <= datetime.fromisoformat(s).date() <= in7],
            key=lambda x: x["start_time"])[:12]
        up_lines = []
        for ev in ev_sorted:
            try:
                lbl = datetime.fromisoformat(ev["start_time"]).strftime("%a %b %d  %I:%M %p").lstrip("0")
            except Exception:
                lbl = ev.get("start_time", "?")[:10]
            icon = {"High": "🔴", "Medium": "🟡"}.get(ev.get("priority", ""), "🟢")
            up_lines.append(f"  {icon}  {lbl}  ·  {ev.get('title','')}")
        fill(self._upcoming_box, up_lines, "No events in the next 7 days.")

    def _calc_streak(self, data):
        streak, day = 0, datetime.now().date()
        for _ in range(365):
            if any(t.get("done") for t in data["daily_todos"].get(day.isoformat(), [])):
                streak += 1
                day -= timedelta(days=1)
            else:
                break
        return streak

    def _rotate_quote(self):
        try:
            if not self._quote_lbl.winfo_exists():
                return
        except Exception:
            return
        self._quote_lbl.config(text=f'"{QUOTES[self._quote_index % len(QUOTES)]}"')
        self._quote_index += 1
        self._quote_job = self.root.after(8000, self._rotate_quote)

