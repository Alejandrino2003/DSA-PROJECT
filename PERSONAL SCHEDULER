    def show_main(self):
        self.clear_window()
        self._start_bg()

        # Solid header — always visible regardless of background
        top = tk.Frame(self.root, bg=CLR_HEADER, height=52)
        top.pack(fill="x")
        top.pack_propagate(False)

        tk.Label(top, text="VIAM", bg=CLR_HEADER, fg="white",
                 font=("Segoe UI", 14, "bold")).pack(side="left", padx=(16, 4), pady=12)
        tk.Label(top, text=f"•  {self.current_user['username']}", bg=CLR_HEADER,
                 fg="#a8d4ff", font=("Segoe UI", 11)).pack(side="left")

        self._clock_lbl = tk.Label(top, text="", bg=CLR_HEADER,
                                   fg="#dce8ff", font=("Segoe UI", 10))
        self._clock_lbl.pack(side="left", padx=18)
        self._tick_clock()

        self._btn(top, "⚙ Background", self.choose_background,
                  "#2563eb", padx=9, pady=3).pack(side="right", padx=6)
        self._btn(top, "Logout", self.logout,
                  CLR_DANGER, padx=12, pady=3).pack(side="right", padx=10)

        # TKEY shell so the notebook chrome is transparent
        shell = tk.Frame(self.root, bg=TKEY)
        shell.pack(fill="both", expand=True, padx=12, pady=(0, 12))

        self.notebook = ttk.Notebook(shell)
        self.notebook.pack(fill="both", expand=True, pady=(8, 0))

        self.tab_dash = ttk.Frame(self.notebook)
        self.tab_cal  = ttk.Frame(self.notebook)
        self.tab_add  = ttk.Frame(self.notebook)

        self.notebook.add(self.tab_dash, text="  📊 Dashboard  ")
        self.notebook.add(self.tab_cal,  text="  📅 Calendar   ")
        self.notebook.add(self.tab_add,  text="  ➕ Add Items  ")

        self._build_dashboard()
        self._build_calendar()
        self._build_add_items()

    def _tick_clock(self):
        try:
            if not self._clock_lbl.winfo_exists():
                return
        except Exception:
            return
        self._clock_lbl.config(text=datetime.now().strftime("%a, %b %d  %I:%M:%S %p"))
        self._clock_job = self.root.after(1000, self._tick_clock)

