    # ── Event form ────────────────────────────────────────────────────────────
    def _form_event(self, parent):
        w   = self._panel_wrap(parent, "New Event", CLR_EVT)
        ttl = self._entry(w);              self._form_row(w, "Title *",               ttl)
        self._ai_date_var, de = self._date_entry(w)
        self._form_row(w, "Date (YYYY-MM-DD) *", de)
        st  = self._entry(w, width=14);    st.insert(0, "9:00 AM")
        self._form_row(w, "Start Time *",  st)
        en  = self._entry(w, width=14);    en.insert(0, "10:00 AM")
        self._form_row(w, "End Time *",    en)
        loc = self._entry(w);              self._form_row(w, "Location",              loc)
        pri = self._combo(w, ["Low","Medium","High"], "Medium")
        self._form_row(w, "Priority",      pri)
        dsc = self._text_row(w, "Description")

        def save():
            title, ds = ttl.get().strip(), self._ai_date_var.get().strip()
            if not title or not ds:
                messagebox.showerror("Error", "Title and Date required."); return
            try:
                s_dt = datetime.strptime(f"{ds} {st.get().strip()}", "%Y-%m-%d %I:%M %p")
                e_dt = datetime.strptime(f"{ds} {en.get().strip()}", "%Y-%m-%d %I:%M %p")
            except Exception:
                messagebox.showerror("Error", "Time format: 9:00 AM"); return
            if e_dt <= s_dt:
                messagebox.showerror("Error", "End must be after start."); return
            data = self.load_data()
            data["events"].append({
                "id": self.next_id(data["events"]), "title": title,
                "description": dsc.get("1.0","end").strip(),
                "start_time": s_dt.isoformat(), "end_time": e_dt.isoformat(),
                "location": loc.get().strip(), "priority": pri.get()})
            self.save_data(data)
            self._refresh_cal_tags(); self._refresh_dashboard()
            for f in (ttl, loc): f.delete(0, "end")
            dsc.delete("1.0", "end")
            messagebox.showinfo("Saved", "✅ Event added!")

        self._btn(w, "  Save Event  ", save, CLR_EVT,
                  padx=14, pady=6).pack(anchor="e", padx=20, pady=14)

    # ── Task form ─────────────────────────────────────────────────────────────
    def _form_task(self, parent):
        w   = self._panel_wrap(parent, "New Task", CLR_SUCCESS)
        ttl = self._entry(w);              self._form_row(w, "Title *",                ttl)
        dv, de = self._date_entry(w);      self._form_row(w, "Due Date (YYYY-MM-DD) *", de)
        tm  = self._entry(w, width=14);    tm.insert(0, "5:00 PM")
        self._form_row(w, "Time Goal",     tm)
        pri = self._combo(w, ["Low","Medium","High"], "Medium")
        self._form_row(w, "Priority",      pri)
        sts = self._combo(w, ["Pending","In Progress","Completed"], "Pending")
        self._form_row(w, "Status",        sts)
        dsc = self._text_row(w, "Description")

        def save():
            title, ds = ttl.get().strip(), dv.get().strip()
            if not title or not ds:
                messagebox.showerror("Error", "Title and Due Date required."); return
            try:
                due = datetime.strptime(f"{ds} {tm.get().strip()}", "%Y-%m-%d %I:%M %p")
            except Exception:
                messagebox.showerror("Error", "Time format: 5:00 PM"); return
            data = self.load_data()
            data["tasks"].append({
                "id": self.next_id(data["tasks"]), "title": title,
                "description": dsc.get("1.0","end").strip(),
                "due_date": due.isoformat(), "priority": pri.get(), "status": sts.get()})
            self.save_data(data); self._refresh_dashboard()
            ttl.delete(0, "end"); dsc.delete("1.0", "end")
            messagebox.showinfo("Saved", "✅ Task added!")

        self._btn(w, "  Save Task  ", save, CLR_SUCCESS,
                  padx=14, pady=6).pack(anchor="e", padx=20, pady=14)

    # ── To-Do form ────────────────────────────────────────────────────────────
    def _form_todo(self, parent):
        w   = self._panel_wrap(parent, "New To-Do", CLR_TODO)
        ttl = self._entry(w);              self._form_row(w, "Title *",             ttl)
        dv, de = self._date_entry(w);      self._form_row(w, "Date (YYYY-MM-DD) *", de)
        pri = self._combo(w, ["Low","Medium","High"], "Low")
        self._form_row(w, "Priority",      pri)
        ntxt = self._text_row(w, "Notes", height=4)

        done_var = tk.BooleanVar()
        drow = tk.Frame(w, bg=PANEL_BG)
        drow.pack(fill="x", padx=20, pady=4)
        tk.Checkbutton(drow, text="Mark as Done", variable=done_var,
                       bg=PANEL_BG, fg=CLR_TEXT, selectcolor=CLR_INPUT_BG,
                       activebackground=PANEL_BG, font=("Segoe UI", 9)).pack(side="left")

        def save():
            title, ds = ttl.get().strip(), dv.get().strip()
            if not title or not ds:
                messagebox.showerror("Error", "Title and Date required."); return
            try:
                datetime.strptime(ds, "%Y-%m-%d")
            except Exception:
                messagebox.showerror("Error", "Date must be YYYY-MM-DD"); return
            data  = self.load_data()
            todos = data["daily_todos"].setdefault(ds, [])
            todos.append({"id": self.next_id(todos), "title": title,
                          "notes": ntxt.get("1.0","end").strip(),
                          "priority": pri.get(), "done": done_var.get()})
            self.save_data(data)
            self._refresh_cal_tags(); self._refresh_dashboard()
            ttl.delete(0, "end"); ntxt.delete("1.0", "end"); done_var.set(False)
            messagebox.showinfo("Saved", "✅ To-Do added!")

        self._btn(w, "  Save To-Do  ", save, "#a37400", fg="white",
                  padx=14, pady=6).pack(anchor="e", padx=20, pady=14)

