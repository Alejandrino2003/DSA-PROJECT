    # ──────────────────────────────────────────────────────────────────────────
    # SETTINGS / DATA HELPERS
    # ──────────────────────────────────────────────────────────────────────────

    def _load_settings(self):
        if not self.settings_path.exists():
            return {}
        try:
            with open(self.settings_path, "r", encoding="utf-8") as f:
                d = json.load(f)
            return d if isinstance(d, dict) else {}
        except Exception:
            return {}

    def _save_settings(self, data):
        try:
            with open(self.settings_path, "w", encoding="utf-8") as f:
                json.dump(data, f, indent=2)
        except Exception:
            pass

    @staticmethod
    def _date_part(s):
        s = (s or "").strip()
        return s[:10] if len(s) >= 10 else s

    @staticmethod
    def hash_password(pw):
        return hashlib.sha256(pw.encode()).hexdigest()

    def load_users(self):
        users = {}
        if not self.users_file.exists():
            return users
        with open(self.users_file, "r", encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    rec = json.loads(line)
                    users[rec["username"].strip().lower()] = rec
                except Exception:
                    pass
        return users

    def save_user(self, username, email, pw_hash):
        rec = {"username": username.strip(), "email": email.strip(), "password_hash": pw_hash}
        with open(self.users_file, "a", encoding="utf-8") as f:
            f.write(json.dumps(rec) + "\n")

    def _user_path(self):
        safe = "".join(c if c.isalnum() else "_" for c in self.current_user["username"].lower())
        return self.data_dir / (safe + ".json")

    def load_data(self):
        path  = self._user_path()
        blank = {"events": [], "tasks": [],
                 "categories": list(DEFAULT_CATEGORIES), "daily_todos": {}}
        if not path.exists():
            return blank
        try:
            with open(path, "r", encoding="utf-8") as f:
                d = json.load(f)
            for k in blank:
                d.setdefault(k, blank[k])
            if not d["categories"]:
                d["categories"] = list(DEFAULT_CATEGORIES)
            return d
        except Exception:
            return blank

    def save_data(self, data):
        with open(self._user_path(), "w", encoding="utf-8") as f:
            json.dump(data, f, indent=2)

    @staticmethod
    def next_id(items):
        return max((i.get("id", 0) for i in items
                    if isinstance(i.get("id"), int)), default=0) + 1

    # ──────────────────────────────────────────────────────────────────────────
    # WINDOW HELPERS
    # ──────────────────────────────────────────────────────────────────────────

    def clear_window(self):
        for job in (self._clock_job, self._quote_job):
            if job:
                try: self.root.after_cancel(job)
                except Exception: pass
        self._clock_job = self._quote_job = None
        for w in self.root.winfo_children():
            w.destroy()

    # Widget factory helpers ───────────────────────────────────────────────────

    def _entry(self, parent, **kw):
        return tk.Entry(parent, font=("Segoe UI", 10),
                        bg=CLR_INPUT_BG, fg=CLR_TEXT, insertbackground=CLR_TEXT,
                        relief=tk.FLAT, highlightthickness=1,
                        highlightbackground=CLR_INPUT_BD, **kw)

    def _combo(self, parent, values, default=""):
        w = ttk.Combobox(parent, values=values, state="readonly", font=("Segoe UI", 10))
        if default:
            w.set(default)
        return w

    def _btn(self, parent, text, command, bg, fg="white", **kw):
        return tk.Button(parent, text=text, command=command,
                         bg=bg, fg=fg, font=("Segoe UI", 10, "bold"),
                         relief=tk.FLAT, cursor="hand2",
                         activebackground=bg, activeforeground=fg, **kw)

    def _form_row(self, parent, label, widget):
        row = tk.Frame(parent, bg=PANEL_BG)
        row.pack(fill="x", padx=20, pady=4)
        tk.Label(row, text=label, width=24, anchor="w",
                 font=("Segoe UI", 9, "bold"),
                 bg=PANEL_BG, fg=CLR_TEXT_LABEL).pack(side="left")
        widget.pack(side="left", fill="x", expand=True)

    def _panel_wrap(self, parent, title, color):
        """Titled glass panel inside an Add-Items sub-tab."""
        wrap = tk.Frame(parent, bg=PANEL_BG,
                        highlightthickness=1, highlightbackground=GLASS_BORDER)
        wrap.pack(fill="both", expand=True, padx=18, pady=14)
        tk.Label(wrap, text=title, font=("Segoe UI", 13, "bold"),
                 bg=PANEL_BG, fg=color).pack(anchor="w", padx=20, pady=(14, 4))
        ttk.Separator(wrap).pack(fill="x", padx=20, pady=(0, 8))
        return wrap

    def _date_entry(self, parent):
        var = tk.StringVar(value=datetime.now().strftime("%Y-%m-%d"))
        ent = self._entry(parent, textvariable=var, width=14)
        return var, ent

    def _text_row(self, parent, label, height=3):
        row = tk.Frame(parent, bg=PANEL_BG)
        row.pack(fill="x", padx=20, pady=4)
        tk.Label(row, text=label, width=24, anchor="w",
                 font=("Segoe UI", 9, "bold"),
                 bg=PANEL_BG, fg=CLR_TEXT_LABEL).pack(side="left")
        t = tk.Text(row, height=height, font=("Segoe UI", 10),
                    bg=CLR_INPUT_BG, fg=CLR_TEXT, insertbackground=CLR_TEXT,
                    relief=tk.FLAT, highlightthickness=1,
                    highlightbackground=CLR_INPUT_BD)
        t.pack(side="left", fill="x", expand=True)
        return t

